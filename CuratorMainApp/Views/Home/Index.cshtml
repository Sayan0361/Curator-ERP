@{
    ViewBag.Title = "Home Page";
}

<h2>Login from Main App</h2>

<form action="https://localhost:44316/Login/Verify" method="post">
    <div>
        <label>Organization Name:</label>
        <input type="text" name="orgName" />
    </div>
    <div>
        <label>User Email:</label>
        <input type="email" name="userEmail" />
    </div>
    <button type="submit">Login to Auth System</button>
</form>